---
title: Home
description: "Haunted ATX offers walking ghost tours through Austin's most haunted streets, historic buildings, and dark hidden history. Book a tour and discover the other side of Austin, TX."
keywords: "ghost tours Austin, haunted Austin, Austin ghost walk, paranormal Austin, haunted history Austin TX, things to do at night Austin"
---

{% extends "layouts/base.njk" %}

{% block head %}
<script src="https://v2.reservationgenie.com/haunted-atx/popup.js"></script>
{% endblock %}

{% block content %}
  <!-- Hero Section: Full-width image background -->
  <section class="relative overflow-hidden bg-gray-900" style="margin-top: -7.5rem; min-height: 100vh;">

    <!-- Background image -->
    <img
      src="{{ '/assets/images/hero.jpg' | url }}"
      alt=""
      aria-hidden="true"
      fetchpriority="high"
      class="absolute inset-0 w-full h-full object-cover object-center">

    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-black/60" aria-hidden="true"></div>

    <!-- Lightning video overlay (mix-blend-mode: screen makes black transparent, lightning glows) -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <iframe
        src="https://www.youtube.com/embed/a_Mz8EJxykQ?autoplay=1&mute=1&loop=1&playlist=a_Mz8EJxykQ&controls=0&rel=0&modestbranding=1&iv_load_policy=3&disablekb=1&playsinline=1"
        frameborder="0"
        allow="autoplay; encrypted-media"
        style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(1.15); width: 177.78vh; height: 56.25vw; min-width: 100%; min-height: 100%; mix-blend-mode: screen; opacity: 0.85;"
        title=""></iframe>
    </div>

    <!-- Content -->
    <div class="relative z-10 flex items-end" style="min-height: 100vh;">
      <div class="w-full text-center text-white">

        <!-- Text + CTAs: constrained width -->
        <div class="max-w-screen-xl px-4 pt-40 pb-8 mx-auto">
          <h1 class="max-w-5xl mx-auto mb-6 font-extrabold tracking-tight leading-none" style="font-size: clamp(2.75rem, 6vw, 5.5rem);">Dare to Discover Austin's Dark Side</h1>
          <p class="max-w-2xl mx-auto mb-8 font-light text-gray-300 md:text-lg lg:text-xl">Austin's Only Ghost Tour on Wheels<span class="hidden md:inline"> —</span><br class="md:hidden"> Prices starting at $49 per person.</p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="{{ client.bookingUrl }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white rounded-lg bg-purple-700 hover:bg-purple-800 focus:ring-4 focus:ring-purple-300 transition-colors">
              Book a Tour
              <svg class="w-5 h-5 ml-2 -mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
              </svg>
            </a>
            <a href="{{ '/tours/' | url }}" class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-gray-200 border border-gray-400 rounded-lg hover:bg-white/10 focus:ring-4 focus:ring-gray-700 transition-colors">
              See Our Tours
            </a>
          </div>
        </div>

        <!-- Fleet image: full viewport width -->
        <div class="mt-10 md:mt-20 px-2 w-full">
          <img
            src="{{ '/assets/images/fleet.png' | url }}"
            alt="Haunted ATX ghost tour vehicles"
            loading="lazy"
            class="hidden md:block w-full animate-fleet-up">
          <img
            src="{{ '/assets/images/black-profile.png' | url }}"
            alt="Haunted ATX ghost tour vehicle"
            loading="lazy"
            class="md:hidden w-full animate-profile-right">
        </div>

      </div>
    </div>

  </section>

  <!-- Marquee Banner -->
  <div class="bg-purple-900 overflow-hidden py-4" aria-hidden="true">
    <div class="marquee-track items-center">
      {% for i in range(0, 8) %}<img src="{{ '/assets/images/ghost.png' | url }}" alt="" class="h-10 w-auto mx-4 opacity-80 inline-block"><span class="text-white font-bold uppercase tracking-widest text-xl px-8">Bring your own booze. We'll bring the boos.</span>{% endfor %}
    </div>
  </div>

  <!-- About / Value Prop Section -->
  <section class="relative overflow-hidden bg-gray-800 text-white">
    <!-- Cobweb corner decoration -->
    <img
      src="{{ '/assets/images/web1.png' | url }}"
      alt=""
      aria-hidden="true"
      class="absolute top-0 left-0 w-auto pointer-events-none select-none"
      style="height: 320px;">
    <div class="max-w-[1300px] mx-auto md:grid md:grid-cols-2" style="min-height: 80vh;">

      <!-- Left: Headline text + CTA -->
      <div class="flex items-center px-5 py-16 md:px-10 bg-gray-800 lg:px-16">
        <div>
          <h2 data-animate="fade-up" class="text-white font-black" style="font-size: clamp(3.5rem, 7vw, 6rem); line-height: 1.0; letter-spacing: -0.02em;">
            Keep<br>Austin<br>Haunted
          </h2>
          <p data-animate="fade-up" style="transition-delay: 0.15s" class="mt-8 text-gray-400 md:text-lg max-w-sm">Austin's dark history is waiting. Join us for a ghost tour unlike any other — on wheels, after dark, through the city's most haunted streets.</p>
          <a data-animate="fade-up" style="transition-delay: 0.3s" href="{{ client.bookingUrl }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center mt-6 px-6 py-3 text-base font-semibold text-white bg-purple-700 hover:bg-purple-800 rounded-lg focus:ring-4 focus:ring-purple-900 transition-colors">
            Book Your Tour
            <svg class="w-5 h-5 ml-2 -mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Full image -->
      <div class="p-8 flex items-center">
        <img data-animate="fade-right" class="w-full h-auto rounded-lg" src="{{ '/assets/images/alley-cropped.jpg' | url }}" alt="Haunted ATX ghost tour vehicle">
      </div>

    </div>
  </section>

  <!-- Tours Preview Section -->
  <section class="bg-gray-900 text-white py-16 px-4">
    <div class="max-w-screen-xl mx-auto">
      <h2 data-animate="fade-up" class="mb-3 font-extrabold tracking-tight text-center" style="font-size: clamp(2.5rem, 8vw, 6.25rem);">Choose Your Tour</h2>
      <p data-animate="fade-up" style="transition-delay: 0.15s" class="mb-12 text-gray-400 text-center md:text-lg  max-w-2xl mx-auto">No prior ghost-hunting experience required — just a sense of adventure.</p>
      <div class="grid gap-8 sm:grid-cols-3">

        <!-- Van Tour — 1st -->
        <a data-animate="fade-up" href="{{ '/tours/public-van-tour/' | url }}" class="group flex flex-col items-center text-center p-6 transition-colors">
          <img
            src="{{ '/assets/images/van-skeleton-cropped.jpg' | url }}"
            alt="Public Van Tour"
            width="288" height="288"
            loading="lazy"
            class="w-full aspect-square sm:w-48 sm:h-48 sm:aspect-auto lg:w-72 lg:h-72 rounded-full object-cover mb-5 transition-opacity group-hover:opacity-90">
          <h3 class="font-bold mb-2 flex items-center justify-center min-h-[7rem] w-full" style="font-size: clamp(1.5rem, 3vw, 2.5rem);">Van Tours</h3>
          <div class="text-purple-400 md:text-lg font-semibold uppercase tracking-widest mb-1">$49 / person</div>
          <p class="text-gray-400 md:text-lg text-sm flex-1">More seats, air conditioning, and a custom art wrap — same haunted Austin history.</p>
          <span class="mt-4 text-purple-400 group-hover:text-purple-300 text-sm font-medium transition-colors">Learn more &rarr;</span>
        </a>

        <!-- Paranormal — 2nd -->
        <a data-animate="fade-up" style="transition-delay: 0.15s" href="{{ '/tours/paranormal-investigation/' | url }}" class="group flex flex-col items-center text-center p-6 transition-colors">
          <img
            src="{{ '/assets/images/para2.jpg' | url }}"
            alt="Paranormal Investigation Experience"
            width="288" height="288"
            loading="lazy"
            class="w-full aspect-square sm:w-48 sm:h-48 sm:aspect-auto lg:w-72 lg:h-72 rounded-full object-cover mb-5 transition-opacity group-hover:opacity-90">
          <h3 class="font-bold mb-2 flex items-center justify-center min-h-[7rem] w-full" style="font-size: clamp(1.2rem, 2.5vw, 2.125rem);">Paranormal Investigation</h3>
          <div class="text-purple-400 text-xs md:text-lg font-semibold uppercase tracking-widest mb-1">$59 / person</div>
          <p class="text-gray-400 text-sm flex-1">Go hands-on with the spirits at The Clay Pit's historic Bertram Building every Saturday night.</p>
          <span class="mt-4 text-purple-400 group-hover:text-purple-300 text-sm font-medium transition-colors">Learn more &rarr;</span>
        </a>

        <!-- Hearse Tour — 3rd -->
        <a data-animate="fade-up" style="transition-delay: 0.3s" href="{{ '/tours/private-hearse-tour/' | url }}" class="group flex flex-col items-center text-center p-6 transition-colors">
          <img
            src="{{ '/assets/images/maddy-loretta-white.jpg' | url }}"
            alt="Public Hearse Limo Tour"
            width="288" height="288"
            loading="lazy"
            class="w-full aspect-square sm:w-48 sm:h-48 sm:aspect-auto lg:w-72 lg:h-72 rounded-full object-cover mb-5 transition-opacity group-hover:opacity-90">
          <h3 class="font-bold mb-2 flex items-center justify-center min-h-[7rem] w-full" style="font-size: clamp(1.5rem, 3vw, 2.5rem);">Hearse Tours</h3>
          <div class="text-purple-400 text-xs md:text-lg font-semibold uppercase tracking-widest mb-1">from $99 / person</div>
          <p class="text-gray-400 text-sm flex-1">Climb into a classic Cadillac hearse converted into a spooky limousine and explore Austin after dark.</p>
          <span class="mt-4 text-purple-400 group-hover:text-purple-300 text-sm font-medium transition-colors">Learn more &rarr;</span>
        </a>

      </div>
    </div>
  </section>

  <!-- Reviews Section -->
  <section class="bg-purple-600 py-16 px-4">
    <div class="max-w-screen-xl mx-auto">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <article data-animate="fade-up" class="rounded-2xl p-8 flex flex-col items-center text-center">
          <div class="flex justify-center gap-1 mb-4">
            {% for i in range(5) %}<svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>{% endfor %}
          </div>
          <p class="text-white text-xl md:text-4xl leading-relaxed flex-1 uppercase">"One of the best haunted tours we have been on and we have done a lot."</p>
          <a href="{{ client.googleBusinessUrl }}" target="_blank" rel="noopener noreferrer" class="mt-6 text-purple-200 font-semibold hover:text-white transition-colors">— Joy</a>
        </article>

        <article data-animate="fade-up" style="transition-delay: 0.1s" class="rounded-2xl p-8 flex flex-col items-center text-center">
          <div class="flex justify-center gap-1 mb-4">
            {% for i in range(5) %}<svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>{% endfor %}
          </div>
          <p class="text-white text-xl md:text-4xl leading-relaxed flex-1 uppercase">"This was the coolest experience! Drove around downtown Austin in a HEARSE!! Would 1000% recommend!"</p>
          <a href="{{ client.googleBusinessUrl }}" target="_blank" rel="noopener noreferrer" class="mt-6 text-purple-200 font-semibold hover:text-white transition-colors">— Kylee</a>
        </article>

        <article data-animate="fade-up" style="transition-delay: 0.2s" class="rounded-2xl p-8 flex flex-col items-center text-center">
          <div class="flex justify-center gap-1 mb-4">
            {% for i in range(5) %}<svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>{% endfor %}
          </div>
          <p class="text-white text-xl md:text-4xl leading-relaxed flex-1 uppercase">"This was so much fun and I even had a few ghostly interactions to my surprise! Do this!!!"</p>
          <a href="{{ client.googleBusinessUrl }}" target="_blank" rel="noopener noreferrer" class="mt-6 text-purple-200 font-semibold hover:text-white transition-colors">— Daphne</a>
        </article>

        <article data-animate="fade-up" style="transition-delay: 0.3s" class="rounded-2xl p-8 flex flex-col items-center text-center">
          <div class="flex justify-center gap-1 mb-4">
            {% for i in range(5) %}<svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>{% endfor %}
          </div>
          <p class="text-white text-xl md:text-4xl leading-relaxed flex-1 uppercase">"Best ghost tour we've ever been on. Highly recommend."</p>
          <a href="{{ client.googleBusinessUrl }}" target="_blank" rel="noopener noreferrer" class="mt-6 text-purple-200 font-semibold hover:text-white transition-colors">— MT DAWG</a>
        </article>

      </div>

      <div class="text-center mt-10">
        <a href="{{ client.googleBusinessUrl }}" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-purple-100 hover:text-white font-semibold transition-colors">
          Read all reviews on Google
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
        </a>
      </div>

    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="relative bg-gray-800 text-white py-12 px-4">
    <!-- Skull decoration: peeks in from left, ~50% off-screen, taller than section -->
    <img
      id="skull-decoration"
      src="{{ '/assets/images/skull-large.png' | url }}"
      alt=""
      aria-hidden="true"
      class="hidden md:block absolute z-0 w-auto pointer-events-none select-none"
      style="top: 50%; left: 4rem; transform: translateX(-50%) translateY(-50%); height: 680px;">
    <div class="relative z-10 max-w-screen-xl mx-auto">
      <div class="text-center mb-10">
        <h2 data-animate="fade-up" class="mb-3 font-extrabold tracking-tight text-center" style="font-size: clamp(2.5rem, 8vw, 6.25rem);">Make Contact</h2>
        <p data-animate="fade-up" style="transition-delay: 0.15s" class="text-gray-400 max-w-2xl mx-auto">Have a question about our tours? We'd love to hear from you.</p>
      </div>
      <div class="max-w-2xl mx-auto">
        <iframe src="https://v2.reservationgenie.com/haunted-atx/contact_form" width="100%" height="610" frameborder="0" style="border: none;" title="Contact Form"></iframe>
      </div>
    </div>
  </section>
{% endblock %}
