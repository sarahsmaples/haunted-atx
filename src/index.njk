---
title: Home
description: "Haunted ATX offers walking ghost tours through Austin's most haunted streets, historic buildings, and dark hidden history. Book a tour and discover the other side of Austin, TX."
keywords: "ghost tours Austin, haunted Austin, Austin ghost walk, paranormal Austin, haunted history Austin TX, things to do at night Austin"
---

{% extends "layouts/base.njk" %}

{% block head %}
<script src="https://v2.reservationgenie.com/haunted-atx/popup.js"></script>
{% endblock %}

{% block content %}
  <!-- Hero Section: Full-width image background -->
  <section class="relative overflow-hidden bg-gray-900" style="margin-top: -7.5rem; min-height: 100vh;">

    <!-- Background image -->
    <img
      src="{{ '/assets/images/hero.jpg' | url }}"
      alt=""
      aria-hidden="true"
      fetchpriority="high"
      class="absolute inset-0 w-full h-full object-cover object-center">

    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-black/60" aria-hidden="true"></div>

    <!-- Content -->
    <div class="relative z-10 flex items-end" style="min-height: 100vh;">
      <div class="max-w-screen-xl px-4 pt-40 pb-10 md:pb-14 mx-auto text-center text-white w-full">
        <h1 class="max-w-4xl mx-auto mb-6 text-4xl font-extrabold tracking-tight leading-none md:text-5xl xl:text-6xl">Dare to Discover Austin's Dark Side</h1>
        <p class="max-w-2xl mx-auto mb-8 font-light text-gray-300 md:text-lg lg:text-xl">Austin's Only Ghost Tour on Wheels — Prices starting at $49 per person.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="{{ client.bookingUrl }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white rounded-lg bg-purple-700 hover:bg-purple-800 focus:ring-4 focus:ring-purple-300 transition-colors">
            Book a Tour
            <svg class="w-5 h-5 ml-2 -mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </a>
          <a href="/tours/" class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-gray-200 border border-gray-400 rounded-lg hover:bg-white/10 focus:ring-4 focus:ring-gray-700 transition-colors">
            See Our Tours
          </a>
        </div>

        <!-- Fleet image: desktop shows fleet.png, mobile shows black-profile.png -->
        <div class="mt-16 md:mt-28 w-[95%] mx-auto">
          <img
            src="{{ '/assets/images/fleet.png' | url }}"
            alt="Haunted ATX ghost tour vehicles"
            loading="lazy"
            class="hidden md:block w-full">
          <img
            src="{{ '/assets/images/black-profile.png' | url }}"
            alt="Haunted ATX ghost tour vehicle"
            loading="lazy"
            class="md:hidden w-full">
        </div>
      </div>
    </div>

  </section>

  <!-- Marquee Banner -->
  <div class="bg-purple-900 overflow-hidden py-4" aria-hidden="true">
    <div class="marquee-track items-center">
      {% for i in range(0, 8) %}<span class="text-white font-bold uppercase tracking-widest text-xl px-8">THRILLS</span><img src="{{ '/assets/images/ghost.png' | url }}" alt="" class="h-10 w-auto mx-4 opacity-80 inline-block"><span class="text-white font-bold uppercase tracking-widest text-xl px-8">CHILLS</span><img src="{{ '/assets/images/ghost.png' | url }}" alt="" class="h-10 w-auto mx-4 opacity-80 inline-block"><span class="text-white font-bold uppercase tracking-widest text-xl px-8">AUTOMOBILES</span><img src="{{ '/assets/images/ghost.png' | url }}" alt="" class="h-10 w-auto mx-4 opacity-80 inline-block">{% endfor %}
    </div>
  </div>

  <!-- About / Value Prop Section -->
  <section class="bg-gray-800 text-white">
    <div class="max-w-[1300px] mx-auto md:grid md:grid-cols-2" style="min-height: 80vh;">

      <!-- Left: Headline text + CTA -->
      <div class="flex items-center px-10 py-16 bg-gray-800 lg:px-16">
        <div>
          <h2 class="text-white font-black" style="font-size: clamp(2.75rem, 7vw, 6rem); line-height: 0.9; letter-spacing: -0.02em;">
            KEEP<br>AUSTIN<br>HAUNTED
          </h2>
          <p class="mt-8 text-gray-400 md:text-lg max-w-sm">Austin's dark history is waiting. Join us for a ghost tour unlike any other — on wheels, after dark, through the city's most haunted streets.</p>
          <a href="{{ client.bookingUrl }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center mt-6 px-6 py-3 text-base font-semibold text-white bg-purple-700 hover:bg-purple-800 rounded-lg focus:ring-4 focus:ring-purple-900 transition-colors">
            Book Your Tour
            <svg class="w-5 h-5 ml-2 -mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Full image -->
      <div class="p-8 md:p-0 flex items-center">
        <img class="w-full h-auto rounded-lg" src="{{ '/assets/images/black-back.png' | url }}" alt="Haunted ATX ghost tour vehicle">
      </div>

    </div>
  </section>

  <!-- Tours Preview Section -->
  <section class="bg-gray-900 text-white py-16 px-4">
    <div class="max-w-screen-xl mx-auto">
      <h2 class="mb-3 font-extrabold tracking-tight text-center" style="font-size: clamp(2.5rem, 8vw, 6.25rem);">Choose Your Tour</h2>
      <p class="mb-12 text-gray-400 text-center max-w-2xl mx-auto">No prior ghost-hunting experience required — just a sense of adventure.</p>
      <div class="grid gap-8 sm:grid-cols-3">

        <a href="/tours/public-hearse-tour/" class="group flex flex-col items-center text-center p-6 transition-colors">
          <img
            src="{{ '/assets/images/black-hearse.jpg' | url }}"
            alt="Public Hearse Limo Tour"
            width="288" height="288"
            loading="lazy"
            class="w-48 h-48 lg:w-72 lg:h-72 rounded-full object-cover mb-5 transition-opacity group-hover:opacity-90">
          <h3 class="text-lg font-bold mb-2">Public Hearse Tour</h3>
          <div class="text-purple-400 text-xs font-semibold uppercase tracking-widest mb-1">$99 / ticket</div>
          <p class="text-gray-400 text-sm flex-1">Climb into a classic Cadillac hearse converted into a spooky limousine and explore Austin after dark.</p>
          <span class="mt-4 text-purple-400 group-hover:text-purple-300 text-sm font-medium transition-colors">Learn more &rarr;</span>
        </a>

        <a href="/tours/public-van-tour/" class="group flex flex-col items-center text-center p-6 transition-colors">
          <img
            src="{{ '/assets/images/black-hearse.jpg' | url }}"
            alt="Public Van Tour"
            width="288" height="288"
            loading="lazy"
            class="w-48 h-48 lg:w-72 lg:h-72 rounded-full object-cover mb-5 transition-opacity group-hover:opacity-90">
          <h3 class="text-lg font-bold mb-2">Public Van Tour</h3>
          <div class="text-purple-400 text-xs font-semibold uppercase tracking-widest mb-1">From $49 / ticket</div>
          <p class="text-gray-400 text-sm flex-1">More seats, air conditioning, and a custom art wrap — same haunted Austin history.</p>
          <span class="mt-4 text-purple-400 group-hover:text-purple-300 text-sm font-medium transition-colors">Learn more &rarr;</span>
        </a>

        <a href="/tours/paranormal-investigation/" class="group flex flex-col items-center text-center p-6 transition-colors">
          <img
            src="{{ '/assets/images/black-hearse.jpg' | url }}"
            alt="Paranormal Investigation Experience"
            width="288" height="288"
            loading="lazy"
            class="w-48 h-48 lg:w-72 lg:h-72 rounded-full object-cover mb-5 transition-opacity group-hover:opacity-90">
          <h3 class="text-lg font-bold mb-2">Paranormal Investigation</h3>
          <div class="text-purple-400 text-xs font-semibold uppercase tracking-widest mb-1">$59 / person</div>
          <p class="text-gray-400 text-sm flex-1">Go hands-on with the spirits at The Clay Pit's historic Bertram Building every Saturday night.</p>
          <span class="mt-4 text-purple-400 group-hover:text-purple-300 text-sm font-medium transition-colors">Learn more &rarr;</span>
        </a>

      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="bg-gray-800 text-white py-12 px-4">
    <div class="max-w-screen-xl mx-auto">
      <div class="max-w-2xl mx-auto text-center mb-10">
        <h2 class="text-3xl font-extrabold tracking-tight mb-3">Get in Touch</h2>
        <p class="text-gray-400">Have a question about our tours? We'd love to hear from you.</p>
      </div>
      <div class="max-w-2xl mx-auto">
        <iframe src="https://v2.reservationgenie.com/haunted-atx/contact_form" width="100%" height="610" frameborder="0" style="border: none;" title="Contact Form"></iframe>
      </div>
    </div>
  </section>
{% endblock %}
