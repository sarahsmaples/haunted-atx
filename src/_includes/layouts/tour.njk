---
layout: layouts/base.njk
---

<!-- Tour Hero -->
<section class="relative overflow-hidden bg-gray-900" style="margin-top: -7.5rem; min-height: 60vh;">
  <img class="absolute inset-0 w-full h-full object-cover object-center" src="{{ heroImage | url }}" alt="{{ tourTitle }}">
  <div class="absolute inset-0 bg-black/65" aria-hidden="true"></div>
  <div class="relative z-10 flex items-end" style="min-height: 60vh;">
    <div class="max-w-screen-xl w-full px-6 pb-14 mx-auto text-white">
      <p class="text-purple-400 text-sm font-semibold uppercase tracking-widest mb-3">Haunted ATX Ghost Tours</p>
      <h1 class="text-4xl md:text-5xl xl:text-6xl tracking-tight leading-none mb-4">{{ tourTitle }}</h1>
      <p class="text-gray-300 text-lg max-w-2xl">{{ tagline }}</p>
    </div>
  </div>
</section>

<!-- Stats Bar -->
<div class="bg-purple-950 border-b border-purple-900 text-white">
  <div class="max-w-screen-xl mx-auto px-6 py-5 grid grid-cols-2 md:grid-cols-4 divide-x divide-purple-900 text-center">
    <div class="px-4">
      <div class="text-xs uppercase tracking-widest text-purple-400 mb-1">Price</div>
      <div class="font-bold text-lg">{{ price }}</div>
    </div>
    <div class="px-4">
      <div class="text-xs uppercase tracking-widest text-purple-400 mb-1">Duration</div>
      <div class="font-bold text-lg">{{ duration }}</div>
    </div>
    <div class="px-4 col-span-2 md:col-span-1 mt-4 md:mt-0">
      <div class="text-xs uppercase tracking-widest text-purple-400 mb-1">Schedule</div>
      <div class="font-bold text-lg">{{ schedule }}</div>
    </div>
    <div class="px-4 col-span-2 md:col-span-1 mt-4 md:mt-0">
      <div class="text-xs uppercase tracking-widest text-purple-400 mb-1">Capacity</div>
      <div class="font-bold text-lg">{{ capacity }}</div>
    </div>
  </div>
</div>

<!-- Page Body -->
<div class="bg-gray-900 text-white">
  <div class="max-w-screen-xl mx-auto px-6 py-16">
    <div class="lg:grid lg:grid-cols-3 lg:gap-16">

      <!-- Main content (injected from tour page) -->
      <div class="lg:col-span-2">
        {{ content | safe }}
      </div>

      <!-- Sticky Booking Sidebar -->
      <aside class="mt-12 lg:mt-0">
        <div class="bg-gray-800 rounded-xl border border-gray-700 p-6 sticky top-28">
          <div class="mb-1">
            <span class="text-3xl font-bold">{{ price }}</span>
          </div>
          <p class="text-gray-400 text-sm mb-6">{{ pricenote }}</p>
          <a href="{{ client.bookingUrl }}" target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center w-full bg-purple-700 hover:bg-purple-800 text-white font-semibold px-6 py-3 rounded-lg transition-colors mb-6">
            Find Available Dates
            <svg class="w-4 h-4 ml-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
          </a>
          <ul class="text-sm text-gray-400 space-y-2">
            {% for perk in perks %}
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              {{ perk }}
            </li>
            {% endfor %}
          </ul>
        </div>
      </aside>

    </div>
  </div>
</div>
