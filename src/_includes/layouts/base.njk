<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Standard meta tags -->
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description or client.description }}">
    {% if keywords %}<meta name="keywords" content="{{ keywords }}">{% endif %}
    <meta name="robots" content="{{ robots or 'index, follow' }}">
    <link rel="canonical" href="{{ client.domain }}{{ page.url }}">

    <!-- Open Graph / Social Sharing -->
    <meta property="og:site_name" content="{{ client.name }}"/>
    <meta property="og:title" content="{% if seoTitle %}{{ seoTitle }}{% elif title and title != 'Home' %}{{ title }} | {{ client.name }}{% else %}{{ client.name }} | {{ client.tagline }}{% endif %}"/>
    <meta property="og:description" content="{{ description or client.description }}"/>
    <meta property="og:type" content="website"/>
    <meta property="og:url" content="{{ client.domain }}{{ page.url }}"/>
    <meta property="og:image" content="{{ client.domain }}/assets/images/og-image.webp"/>
    <meta property="og:image:secure_url" content="{{ client.domain }}/assets/images/og-image.webp"/>
    <meta property="og:image:width" content="1200"/>
    <meta property="og:image:height" content="630"/>
    <meta property="og:locale" content="en_US"/>

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="{% if seoTitle %}{{ seoTitle }}{% elif title and title != 'Home' %}{{ title }} | {{ client.name }}{% else %}{{ client.name }} | {{ client.tagline }}{% endif %}"/>
    <meta name="twitter:description" content="{{ description or client.description }}"/>
    <meta name="twitter:image" content="{{ client.domain }}/assets/images/og-image.webp"/>

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="{{ '/assets/favicons/apple-touch-icon.png' | url }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ '/assets/favicons/favicon-32x32.png' | url }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ '/assets/favicons/favicon-16x16.png' | url }}">
    <link rel="manifest" href="{{ '/assets/favicons/site.webmanifest' | url }}">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">

    <!-- Preconnect for performance (Google Fonts) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Sitewide Stylesheets -->
    <link rel="stylesheet" href="{{ '/assets/css/styles.css' | url }}">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400..900&family=Luckiest+Guy&family=Nunito:ital,wght@0,200..1000;1,200..1000&family=Rammetto+One&family=Roboto:ital,wght@0,100..900;1,100..900&family=Slackey&family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&family=Staatliches&family=UnifrakturMaguntia&display=swap" rel="stylesheet">

    {% block head %}{% endblock %}

    <title>{% if seoTitle %}{{ seoTitle }}{% elif title and title != 'Home' %}{{ title }} | {{ client.name }}{% else %}{{ client.name }} | {{ client.tagline }}{% endif %}</title>

    <!-- Schema.org: TouristAttraction (https://schema.org/TouristAttraction) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "TouristAttraction",
      "name": "{{ client.name }}",
      "url": "{{ client.domain }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ client.domain }}/assets/images/logo_mobile.png"
      },
      "image": "{{ client.domain }}/assets/images/og-image.webp",
      "description": "{{ client.description }}",
      "telephone": "{{ client.phone }}",
      "email": "{{ client.email }}",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "{{ client.address.street }}",
        "addressLocality": "{{ client.address.city }}",
        "addressRegion": "{{ client.address.state }}",
        "postalCode": "{{ client.address.zip }}",
        "addressCountry": "{{ client.address.country }}"
      },
      "openingHoursSpecification": {{ client.hours | dump | safe }},
      "hasMap": "{{ client.mapUrl }}",
      "sameAs": [{% for profile in client.social %}"{{ profile.url }}"{% if not loop.last %},{% endif %}{% endfor %}]
    }
    </script>

    <!-- Page-specific schema block (override in child templates) -->
    {% block schema %}{% endblock %}

    <!-- Google Analytics -->
    {% if client.gtag %}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ client.gtag }}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{{ client.gtag }}');
    </script>
    {% endif %}

  </head>

  <body>
    {% include "components/header.njk" %}
    <main>
      {% block content %}{% endblock %}
    </main>
    {% include "components/footer.njk" %}
    <script src="{{ '/assets/js/main.js' | url }}"></script>
  </body>
</html>
